# ── Application ─────────────────────────────────────────────────
APP_NAME=SmartPost
APP_ENV=development           # development | production
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smartpost

# ── Email (SMTP) ─────────────────────────────────────────────────
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=noreply@iaacollege.ac.tz
MAIL_FROM_NAME=SmartPost - IAA College
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── File Storage ─────────────────────────────────────────────────
UPLOAD_DIR=uploads            # relative to backend root
MAX_FILE_SIZE_MB=5
ALLOWED_EXTENSIONS=pdf,jpg,png

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
